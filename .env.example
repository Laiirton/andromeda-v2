# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: Supabase → Settings → API

# URL do projeto (ex: https://abcdefgh.supabase.co)
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Chave service_role (NÃO use a anon key — precisa de permissão total no Storage)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Chrome (necessário para enviar vídeos MP4/H.264 via WhatsApp) ────────────
# O Chromium embutido não suporta H.264/AAC (codecs licenciados).
# Para usar !tiktok e outros comandos de vídeo, instale o Google Chrome e informe
# o caminho do executável abaixo.
#
# Exemplos por SO:
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows: C:\Program Files (x86)\Google\Chrome\Application\chrome.exe
#   Linux:   /usr/bin/google-chrome-stable
#
# Deixe em branco para usar o Chromium padrão (vídeos podem não funcionar).
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# ─── Debug (opcional) ─────────────────────────────────────────────────────────
# DEBUG=true
